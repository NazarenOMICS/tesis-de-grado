label = "GT +1", color = ORG_COLORS["Bacteria"], size = 3.2, hjust = 0) +
annotate("text", x = GT_YEAST + 0.08, y = 0.8,
label = "GT -1", color = ORG_COLORS["Yeast"],    size = 3.2, hjust = 0) +
